# If your app registration already exists in your tenant, you can pre-fill these items.
# if you dont already have app registration, you can allow the wizard to create one for you, just be sure to allow public client flow when prompted

$clientID = "" # (application id)
$tenantID = "" # (directory id)
$clientSecret= ""


$hudubaseurl = "yoururl.huducloud.com"
$huduapikey = ""

# Optional: file types that should become folder-level Hudu index articles
# instead of being converted into one article per file.
# $SharePointIndexOnlyExtensions = @(".eps", ".ai", ".psd", ".indd")

# Optional: process one site at a time and clear downloaded/converted working
# files after each site. Useful for runners with limited free disk space.
# $SharePointLowDiskMode = $true

# Optional: skip SharePoint drive items already completed in a prior run.
# Uses logs\sharepoint-migration-state.jsonl and compares SharePoint item ID + ETag.
# $SharePointResumeFromState = $true
# $SharePointResumeIgnoreETag = $false

# Optional: before stubbing an article, skip if an article with the same exact
# name already exists in the target Hudu company/global KB.
# $SharePointSkipExistingArticles = $true

# Optional: upload PDFs as attached files on stub articles instead of converting
# them. Article names keep the .pdf extension for post-run is_upload updates.
# $SharePointPdfUploadAsFile = $true

# Optional: exclude SharePoint sites from source selection by site displayName
# or name. Matching is case/punctuation-insensitive.
# $SharePointSiteSkipNames = @(
#   "Archive",
#   "Old Client Portal"
# )

# Optional: build and use a fuzzy SharePoint client-list to Hudu company map.
# Defaults shown here.
# $SharePointClientAttributionEnabled = $true
# $SharePointClientAttributionAutoApply = $true
# $SharePointClientAttributionClientsPath = ".\clients.json"
# clients.json can be a string array, or objects with name/title, aliases,
# huduCompanyId/companyId, and huduCompanyName/companyName.
# $SharePointClientAttributionUseCachedMap = $true
# $SharePointClientAttributionForceRebuildMap = $false
# $SharePointClientAttributionListNames = @("Client List")
# $SharePointClientAttributionMinScore = 95
# $SharePointClientAttributionMinGap = 5
# $SharePointClientAttributionListItemMinScore = 95
# $SharePointClientAttributionListItemMinGap = 3
# $SharePointClientAttributionCreateMissing = $false

# Optional: when selecting "Match/Create one company per SharePoint site",
# tune matching and whether missing companies should be created.
# $SharePointSiteCompanyMinScore = 95
# $SharePointSiteCompanyMinGap = 5
# $SharePointSiteCompanyCreateMissing = $true
# $SharePointSiteCompanyUseCachedMap = $true
# $SharePointSiteCompanyForceRebuildMap = $false

# Optional: export selected SharePoint lists as per-company JSON bundles
# instead of trying to turn structured inventory records into articles.
# Matches also work when SharePoint appends suffixes like "_[DEMO]".
# $SharePointStructuredListJsonNames = @(
#   "Mapped Drives",
#   "Mail Flow",
#   "Domain/Forest info",
#   "Software Shares",
#   "Core Networking",
#   "Products",
#   "Printers",
#   "Active Servers",
#   "UPS - Battery Backups",
#   "Network Devices",
#   "Web Hosting",
#   "Locations",
#   "Important Client Notes",
#   "Primary Contact",
#   "3rd Party - Escalation Contact Info",
#   "ISP Info",
#   "Connectivity"
# )

. .\Sharepoint-Migration.ps1
